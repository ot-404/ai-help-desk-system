# Flask
FLASK_ENV=development
SECRET_KEY=change-me-in-production
JWT_SECRET_KEY=change-me-too

# Database (defaults to local SQLite if unset)
DATABASE_URL=sqlite:///instance/ai_hds.db

# LLM provider (optional). If OPENAI_API_KEY is unset the app uses a
# built-in mock model so everything still runs end-to-end.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
