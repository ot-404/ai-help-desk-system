# Flask
SECRET_KEY=change-me-in-production
JWT_SECRET_KEY=change-me-too-use-32-plus-chars

# Database (defaults to local SQLite if unset).
# In production use a PostgreSQL URL, e.g. postgresql://user:pass@host/db
DATABASE_URL=sqlite:///instance/lumo.db

# CORS (defaults to * if unset)
CORS_ORIGINS=*

# LLM provider — all optional. With no keys, Lumo uses a built-in heuristic
# mock so every AI feature still works locally.
# Priority: Anthropic -> OpenAI-compatible -> mock.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Point at any OpenAI-compatible endpoint (Groq, OpenRouter, Together, …).
OPENAI_BASE_URL=https://api.openai.com/v1
